# Application
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://promoflow:promoflow@localhost:5432/promoflow

# Aliyun OSS
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET_NAME=promo-flow
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_DOMAIN=https://promo-flow.oss-cn-hangzhou.aliyuncs.com

# Feishu (Lark)
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_VERIFICATION_TOKEN=your-verification-token
FEISHU_ENCRYPT_KEY=your-encrypt-key
FEISHU_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# AI - Qianwen (Aliyun DashScope)
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_VISION_MODEL=qwen-vl-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
DASHSCOPE_RAG_MODEL=qwen3.5-flash

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
