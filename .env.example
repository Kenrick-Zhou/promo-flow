# Application
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://promoflow:promoflow@localhost:5432/promoflow

# Aliyun OSS
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET_NAME=promo-flow
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_DOMAIN=https://promo-flow.oss-cn-hangzhou.aliyuncs.com

# Feishu (Lark)
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_VERIFICATION_TOKEN=your-verification-token
FEISHU_ENCRYPT_KEY=your-encrypt-key
FEISHU_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# AI - Qianwen (Aliyun DashScope)
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_VISION_MODEL=qwen-vl-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
DASHSCOPE_RAG_MODEL=qwen3.5-flash

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Search: Query Understanding ──────────────────────────────
SEARCH_ENABLE_LLM_QUERY_PARSE=true
SEARCH_LLM_QUERY_PARSE_MODEL=qwen3.5-flash
SEARCH_LLM_QUERY_PARSE_TIMEOUT_S=5

# ── Search: Multi-path Recall ────────────────────────────────
SEARCH_VECTOR_RECALL_LIMIT=50
SEARCH_FTS_RECALL_LIMIT=50
SEARCH_TAG_RECALL_LIMIT=30
SEARCH_RRF_K=60
# Recall strategy: "zhparser" uses PostgreSQL full-text search, "ilike" is fallback
SEARCH_FTS_BACKEND=zhparser
# PostgreSQL text search configuration name, e.g. zhcfg
SEARCH_FTS_ZH_TSCONFIG=zhcfg

# ── Search: Business Scoring ─────────────────────────────────
SEARCH_SCORE_CONTENT_TYPE_MATCH=80
SEARCH_SCORE_TAG_EXACT=100
SEARCH_SCORE_TAG_PHRASE=85
SEARCH_SCORE_AI_KEYWORD_EXACT=70
SEARCH_SCORE_AI_KEYWORD_PHRASE=55
SEARCH_SCORE_TITLE_EXACT=60
SEARCH_SCORE_TITLE_PHRASE=45
SEARCH_SCORE_CATEGORY_EXACT=40
SEARCH_SCORE_CATEGORY_PHRASE=30
SEARCH_SCORE_MUST_TERM_DESC=20
SEARCH_SCORE_MUST_TERM_SUMMARY=15
SEARCH_SCORE_FTS_MAX=30
SEARCH_SCORE_VECTOR_MAX=25
SEARCH_SCORE_FRESHNESS_MAX=5

# ── Search: LLM Rerank ───────────────────────────────────────
SEARCH_ENABLE_LLM_RERANK=true
SEARCH_LLM_RERANK_MODEL=qwen3.5-flash
SEARCH_LLM_RERANK_TOP_K=10
SEARCH_LLM_RERANK_TIMEOUT_S=8

# ── Search: Observability ────────────────────────────────────
SEARCH_DEBUG_TIMING=false

# Hot Score
HOT_SCORE_VIEW_WEIGHT=1.0
HOT_SCORE_DOWNLOAD_WEIGHT=5.0
HOT_SCORE_FRESHNESS_HALF_LIFE_DAYS=10
HOT_SCORE_TIME_DECAY_LAMBDA=0.05
