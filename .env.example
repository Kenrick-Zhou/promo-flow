# Application
APP_ENV=development # 应用运行环境，常见值为 development / test / production
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32 # 应用签名密钥，用于 JWT、会话签名等安全相关场景

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://promoflow:promoflow@localhost:5432/promoflow # 数据库连接串，使用 asyncpg 驱动连接 PostgreSQL，并承载 pgvector 能力

# Aliyun OSS
OSS_ACCESS_KEY_ID=your-access-key-id # 阿里云 OSS 访问密钥 ID，用于服务端上传、签名和资源管理
OSS_ACCESS_KEY_SECRET=your-access-key-secret # 阿里云 OSS 访问密钥 Secret，需与 AccessKey ID 配套使用
OSS_BUCKET_NAME=promo-flow # OSS Bucket 名称，营销素材实际存储位置
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com # OSS 区域接入点，决定请求发往哪个地域
OSS_BUCKET_DOMAIN=https://promo-flow.oss-cn-hangzhou.aliyuncs.com # Bucket 对外访问域名，用于生成资源访问地址

# Feishu (Lark)
FEISHU_APP_ID=your-feishu-app-id # 飞书应用 App ID，用于 OAuth 和开放平台接口鉴权
FEISHU_APP_SECRET=your-feishu-app-secret # 飞书应用 App Secret，用于换取 token 等服务端调用
FEISHU_VERIFICATION_TOKEN=your-verification-token # 飞书事件订阅验证令牌，用于校验回调请求来源
FEISHU_ENCRYPT_KEY=your-encrypt-key # 飞书事件加密密钥，启用加密回调时用于解密消息体
FEISHU_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback # 飞书 OAuth 登录成功后的后端回调地址

# AI - Qianwen (Aliyun DashScope)
DASHSCOPE_API_KEY=your-dashscope-api-key # DashScope 平台 API Key，用于调用通义千问相关模型
DASHSCOPE_VISION_MODEL=qwen-vl-plus # 多模态视觉模型，用于分析图片/视频帧等内容
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3 # 向量化模型，用于生成检索和 RAG 所需的 embedding
DASHSCOPE_RAG_MODEL=qwen3.5-flash # 通用推理/问答模型，用于摘要、问答或 RAG 生成
DASHSCOPE_RAG_TIMEOUT_S=20 # RAG 阶段超时时间，单位秒，避免模型长时间无响应

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"] # 允许跨域访问的前端来源列表，供浏览器调用后端 API 使用


# == Search Configuration =====================================
# 搜索配置整体说明：
# 1) 先由 LLM 解析用户查询，抽取关键词、意图和约束；
# 2) 再并行走向量召回、全文检索召回、标签召回等多路召回；
# 3) 将不同召回结果做融合（RRF），再按业务规则加权打分；
# 4) 如开启，则对候选窗口做一次 LLM rerank，可只保留其中的子集；
# 5) 最后按配置决定是否在 API 响应中返回 timing，同时始终记录结构化 timing 日志。
# ── Search: Query Understanding ──────────────────────────────
SEARCH_ENABLE_LLM_QUERY_PARSE=true # 是否启用 LLM 查询解析，用于把自然语言问题拆成结构化检索条件
SEARCH_LLM_QUERY_PARSE_MODEL=qwen3.5-flash # 查询解析阶段使用的模型名称
SEARCH_LLM_QUERY_PARSE_TIMEOUT_S=5 # 查询解析阶段超时时间，单位秒

# ── Search: Multi-path Recall ────────────────────────────────
SEARCH_VECTOR_RECALL_LIMIT=50 # 向量召回的候选数量上限，控制语义检索返回多少条初选结果
SEARCH_FTS_RECALL_LIMIT=50 # 全文检索召回的候选数量上限
SEARCH_TAG_RECALL_LIMIT=30 # 标签匹配召回的候选数量上限
SEARCH_RRF_K=60 # Reciprocal Rank Fusion 的 K 参数，影响多路结果融合时的排序平滑程度
# Recall strategy: "zhparser" uses PostgreSQL full-text search, "ilike" is fallback
SEARCH_FTS_BACKEND=zhparser # 全文检索后端实现，zhparser 为中文分词 FTS，ilike 为简单模糊匹配兜底
# PostgreSQL text search configuration name, e.g. zhcfg
SEARCH_FTS_ZH_TSCONFIG=zhcfg # PostgreSQL 中文全文检索配置名，需与数据库中安装的文本搜索配置一致

# ── Search: Business Scoring ─────────────────────────────────
# 业务打分说明：以下分值用于对召回结果做二次排序。
# 一般来说，越能直接表达“强相关”的信号，权重越高；
# 最终会叠加文本、标签、标题、分类、向量和新鲜度等多个维度。
SEARCH_SCORE_CONTENT_TYPE_MATCH=80 # 内容类型命中时的加分，例如用户明确搜图片/视频等类型
SEARCH_SCORE_TAG_EXACT=100 # 标签精确命中时的加分，通常是非常强的相关性信号
SEARCH_SCORE_TAG_PHRASE=85 # 标签短语/部分命中时的加分
SEARCH_SCORE_AI_KEYWORD_EXACT=70 # AI 抽取关键词精确命中时的加分
SEARCH_SCORE_AI_KEYWORD_PHRASE=55 # AI 抽取关键词短语/部分命中时的加分
SEARCH_SCORE_TITLE_EXACT=60 # 标题精确命中时的加分
SEARCH_SCORE_TITLE_PHRASE=45 # 标题短语/部分命中时的加分
SEARCH_SCORE_CATEGORY_EXACT=40 # 分类精确命中时的加分
SEARCH_SCORE_CATEGORY_PHRASE=30 # 分类短语/部分命中时的加分
SEARCH_SCORE_MUST_TERM_DESC=20 # 必含词在描述字段命中时的加分
SEARCH_SCORE_MUST_TERM_SUMMARY=15 # 必含词在摘要字段命中时的加分
SEARCH_SCORE_FTS_MAX=30 # 全文检索通道可贡献的最大分值上限
SEARCH_SCORE_VECTOR_MAX=25 # 向量检索通道可贡献的最大分值上限
SEARCH_SCORE_FRESHNESS_MAX=5 # 新鲜度维度可贡献的最大分值上限，避免旧内容长期霸榜

# ── Search: LLM Rerank ───────────────────────────────────────
# Rerank 说明：召回与业务打分后，先截取一个候选窗口，再交给 LLM 做更细粒度排序。
# LLM 可以只返回其中一部分结果；未被返回的候选会被视为显式剔除，而不是再补回尾部结果。
SEARCH_ENABLE_LLM_RERANK=true # 是否启用 LLM 重排序，对初排结果做语义级精排
SEARCH_LLM_RERANK_MODEL=qwen3.5-flash # 重排序阶段使用的模型名称
SEARCH_LLM_RERANK_CANDIDATE_LIMIT=30 # 进入 LLM 重排序的候选窗口大小，仅对该窗口内候选做精排/过滤
SEARCH_LLM_RERANK_TIMEOUT_S=8 # LLM 重排序阶段超时时间，单位秒

# ── Search: Observability ────────────────────────────────────
SEARCH_DEBUG_TIMING=false # 是否在 API 响应中附带 timing 字段；结构化 timing 日志会始终记录


# == Hot Score =============================================
# 热度分说明：热度分通常由浏览、下载和时间衰减共同组成。
# 浏览/下载越多，分数越高；发布时间越久，分数会按衰减参数逐步下降，
# 这样既能体现热门程度，也能避免老内容长期占据前排。
HOT_SCORE_VIEW_WEIGHT=1.0 # 浏览次数权重，每次浏览对热度分的贡献系数
HOT_SCORE_DOWNLOAD_WEIGHT=5.0 # 下载次数权重，通常高于浏览，表示更强的用户兴趣信号
HOT_SCORE_FRESHNESS_HALF_LIFE_DAYS=10 # 新鲜度半衰期（天），表示内容热度每隔多少天衰减到一半附近
HOT_SCORE_TIME_DECAY_LAMBDA=0.05 # 时间衰减系数，数值越大，旧内容热度下降越快
